# Copy to .env next to docker-compose.yml and fill in real values.
# Never commit .env; it is gitignored and dockerignored.

# Target Scanopy instance. host.docker.internal reaches the Docker host.
SCANOPY_BASE_URL=http://host.docker.internal:60072

# Scanopy user API key (Platform > API Keys; starts with 'scp_u_').
SCANOPY_API_KEY=scp_u_replace-me

# Arborist's own HTTP bearer secret — at least 16 characters, NOT the Scanopy
# key. Generate one with: openssl rand -hex 24
ARBORIST_AUTH_TOKEN=replace-me-with-16-plus-chars

# Optional: pin Arborist to a single Scanopy network.
#SCANOPY_NETWORK_ID=
